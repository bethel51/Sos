# Silent SOS - Production Environment Configuration Template

# Server Settings
PORT=3000
NODE_ENV=production
JWT_SECRET=your_super_secret_jwt_key_here

# Twilio Configuration (Real SMS dispatching)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Brevo SMS Configuration (Alternative SMS dispatching)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER=SilentSOS

# SMTP configuration (Real email dispatching)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password_here

# Production Security & Access Settings
ADMIN_TOKEN=your_secure_admin_portal_token_here
CORS_ORIGIN=https://yourproductionfrontenddomain.com

